{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://flow.dev/schemas/project/flow.v1.json",
  "version": "1.0.0",
  "title": "Flow Project",
  "description": "The canonical Flow project file. Contains the entire project state in a single self-describing JSON document. Large projects may use the directory-based form (timeline.otio + actions.jsonl + ...) for performance, but this file is the round-trippable canonical form.",
  "status": "Draft",

  "type": "object",
  "required": ["version", "metadata", "timeline", "assets", "actions", "plugins"],
  "additionalProperties": false,
  "properties": {
    "version": {
      "description": "Schema version of this file. Always 1.0.0 for this spec.",
      "const": "1.0.0"
    },
    "metadata": { "$ref": "#/$defs/project_metadata" },
    "timeline": { "$ref": "#/$defs/timeline" },
    "assets": { "$ref": "#/$defs/assets" },
    "actions": { "$ref": "#/$defs/actions_log" },
    "plugins": { "$ref": "#/$defs/plugins" }
  },

  "$defs": {
    "project_metadata": {
      "type": "object",
      "required": ["id", "name", "created_at", "updated_at"],
      "properties": {
        "id": { "type": "string", "pattern": "^proj_[0-9a-f]{32}$" },
        "name": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" },
        "updated_at": { "type": "string", "format": "date-time" },
        "spec": { "$ref": "#/$defs/project_spec" },
        "tags": { "type": "array", "items": { "type": "string" } }
      }
    },
    "project_spec": {
      "type": "object",
      "required": ["fps", "resolution", "sample_rate", "channels"],
      "properties": {
        "fps": { "type": "number", "exclusiveMinimum": 0 },
        "resolution": {
          "type": "object",
          "required": ["width", "height"],
          "properties": {
            "width":  { "type": "integer", "minimum": 1 },
            "height": { "type": "integer", "minimum": 1 }
          }
        },
        "sample_rate": { "type": "integer", "minimum": 1 },
        "channels": { "type": "integer", "minimum": 1, "maximum": 32 },
        "color_space": { "enum": ["bt601", "bt709", "bt2020"] },
        "color_range": { "enum": ["tv", "pc"] },
        "pixel_format": { "enum": ["yuv420p", "yuv422p", "yuv444p", "rgb24", "rgba"] }
      }
    },

    "timeline": {
      "description": "An OTIO Timeline.1 JSON object. See https://opentimelineio.readthedocs.io/. Flow extensions are added via metadata keys (prefixed 'flow.') and via SchemaDef nodes.",
      "type": "object",
      "required": ["OTIO_SCHEMA", "name", "tracks"],
      "properties": {
        "OTIO_SCHEMA": { "const": "Timeline.1" },
        "name": { "type": "string" },
        "metadata": { "type": "object" },
        "tracks": { "type": "object" }
      }
    },

    "assets": {
      "description": "All media assets referenced by the project. Each asset has a stable ID, a reference, and metadata.",
      "type": "object",
      "required": ["items"],
      "properties": {
        "items": {
          "type": "array",
          "items": { "$ref": "#/$defs/asset" }
        }
      }
    },
    "asset": {
      "type": "object",
      "required": ["id", "reference", "metadata"],
      "properties": {
        "id": { "type": "string", "pattern": "^asset_[0-9a-f]{32}$" },
        "reference": {
          "oneOf": [
            { "$ref": "#/$defs/external_reference" },
            { "$ref": "#/$defs/generated_reference" },
            { "$ref": "#/$defs/missing_reference" }
          ]
        },
        "metadata": {
          "type": "object",
          "properties": {
            "duration_us": { "type": "integer", "minimum": 0 },
            "width":       { "type": "integer", "minimum": 1 },
            "height":      { "type": "integer", "minimum": 1 },
            "fps":         { "type": "number" },
            "codec":       { "type": "string" },
            "container":   { "type": "string" },
            "size_bytes":  { "type": "integer", "minimum": 0 },
            "checksum":    { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
            "checksum_at": { "type": "string", "format": "date-time" },
            "last_accessed_at": { "type": "string", "format": "date-time" },
            "usage_count": { "type": "integer", "minimum": 0 }
          }
        }
      }
    },
    "external_reference": {
      "type": "object",
      "required": ["kind", "target_url"],
      "properties": {
        "kind": { "const": "external" },
        "target_url": { "type": "string", "minLength": 1 },
        "available_range": { "$ref": "#/$defs/time_range" }
      }
    },
    "generated_reference": {
      "type": "object",
      "required": ["kind", "generated_kind"],
      "properties": {
        "kind": { "const": "generated" },
        "generated_kind": { "enum": ["solid_color", "noise", "text", "gradient", "bars"] },
        "params": { "type": "object" }
      }
    },
    "missing_reference": {
      "type": "object",
      "required": ["kind", "reason"],
      "properties": {
        "kind": { "const": "missing" },
        "reason": { "type": "string" },
        "last_known_path": { "type": "string" }
      }
    },

    "actions_log": {
      "description": "The action log. Each entry is an applied action with its inverse and result.",
      "type": "object",
      "required": ["entries"],
      "properties": {
        "entries": {
          "type": "array",
          "items": { "$ref": "#/$defs/action_entry" }
        }
      }
    },
    "action_entry": {
      "type": "object",
      "required": ["v", "id", "ts", "actor", "action", "inverse", "result"],
      "properties": {
        "v": { "const": 1 },
        "id": { "type": "string", "pattern": "^act_[0-9a-f]{32}$" },
        "ts": { "type": "string", "format": "date-time" },
        "actor": { "type": "string" },
        "intent": { "type": "string" },
        "action": { "type": "object" },
        "inverse": { "type": "object" },
        "result": { "type": "object" }
      }
    },

    "plugins": {
      "description": "All plugins enabled for this project. Each plugin has a manifest reference and a version pin.",
      "type": "object",
      "required": ["items"],
      "properties": {
        "items": {
          "type": "array",
          "items": { "$ref": "#/$defs/plugin_ref" }
        }
      }
    },
    "plugin_ref": {
      "type": "object",
      "required": ["id", "version", "enabled"],
      "properties": {
        "id": { "type": "string" },
        "version": { "type": "string" },
        "enabled": { "type": "boolean" },
        "config": { "type": "object" }
      }
    },

    "rational_time": {
      "type": "object",
      "required": ["value", "rate"],
      "properties": {
        "value": { "type": "number" },
        "rate":  { "type": "number", "exclusiveMinimum": 0 }
      }
    },
    "time_range": {
      "type": "object",
      "required": ["start_time", "duration"],
      "properties": {
        "start_time": { "$ref": "#/$defs/rational_time" },
        "duration":    { "$ref": "#/$defs/rational_time" }
      }
    }
  },

  "examples": [
    {
      "version": "1.0.0",
      "metadata": {
        "id": "proj_0123456789abcdef0123456789abcdef",
        "name": "My Launch Video",
        "description": "30-second product launch teaser",
        "created_at": "2026-07-17T00:00:00Z",
        "updated_at": "2026-07-17T04:00:00Z",
        "spec": {
          "fps": 30,
          "resolution": { "width": 1080, "height": 1920 },
          "sample_rate": 48000,
          "channels": 2,
          "color_space": "bt709",
          "color_range": "tv",
          "pixel_format": "yuv420p"
        },
        "tags": ["product", "vertical", "tiktok"]
      },
      "timeline": {
        "OTIO_SCHEMA": "Timeline.1",
        "name": "My Launch Video",
        "metadata": { "flow": { "schema_version": 1 } },
        "tracks": {
          "OTIO_SCHEMA": "Stack.1",
          "name": "tracks",
          "children": []
        }
      },
      "assets": {
        "items": [
          {
            "id": "asset_aabbccdd00112233aabbccdd00112233",
            "reference": {
              "kind": "external",
              "target_url": "media://interview.mp4",
              "available_range": {
                "start_time": { "value": 0, "rate": 30 },
                "duration":   { "value": 1800, "rate": 30 }
              }
            },
            "metadata": {
              "duration_us": 60000000,
              "width": 1920, "height": 1080, "fps": 30,
              "codec": "h264", "container": "mp4",
              "size_bytes": 52428800,
              "checksum": "sha256:e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855"
            }
          }
        ]
      },
      "actions": { "entries": [] },
      "plugins": {
        "items": [
          { "id": "core", "version": "1.0.0", "enabled": true },
          { "id": "ai.upscale", "version": "1.0.0", "enabled": true }
        ]
      }
    }
  ]
}
